# .config: ignore by default; only listed paths are tracked
.config/*
!.config/starship.toml
!.config/btop/
!.config/btop/**
!.config/colors/
!.config/colors/**
!.config/delta/
!.config/delta/**
!.config/dust/
!.config/dust/**
!.config/htop/
!.config/htop/**
!.config/k9s/
!.config/k9s/**
!.config/lazydocker/
!.config/lazydocker/**
!.config/lazygit/
!.config/lazygit/**
# lnav: only .gitkeep (local log viewer state stays untracked)
!.config/lnav/
.config/lnav/*
!.config/lnav/.gitkeep
!.config/mise/
!.config/mise/config.toml.template
!.config/nvim/
!.config/nvim/**
!.config/thefuck/
!.config/thefuck/**
!.config/wezterm/
!.config/wezterm/**
!.config/yazi/
!.config/yazi/**

# After all `!` rules: globals apply here too (later pattern wins over `!.config/.../**`)
__pycache__/
.config/nvim/pack/
.DS_Store
*.py[cod]
